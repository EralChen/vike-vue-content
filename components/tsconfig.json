{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "../env.d.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.vue"
  ],
  "exclude": [
    "dist",
    "vite.config.ts"
  ],

  
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "rootDir": "./",
    "outDir": "dist",
    
    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Store it outside dist to prevent cache issues during parallel builds.
    "tsBuildInfoFile": "./node_modules/.tmp/components.tsbuildinfo"
  }
}
