{
  "name": "vike-vue-content",
  "version": "0.0.1",
  "description": "Content rendering framework for Vike and Vue documentation sites",
  "author": "EralChen",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "vike",
    "vike-vue",
    "vue",
    "content",
    "docs",
    "markdown"
  ],
  "scripts": {
    "build": "bash build.sh"
  },
  "exports": {
    "./components/content-renderer": {
      "import": "./components/content-renderer/index.es.js",
      "types": "./components/content-renderer/index.d.ts"
    },
    "./components/hello-world": {
      "import": "./components/hello-world/index.es.js",
      "types": "./components/hello-world/index.d.ts"
    },
    "./composables/hello": {
      "import": "./composables/hello/index.es.js",
      "types": "./composables/hello/index.d.ts"
    },
    "./config": "./config/+config.js",
    "./query": {
      "import": "./query/index.es.js",
      "types": "./query/index.d.ts"
    },
    "./shared/types": {
      "import": "./shared/types/index.es.js",
      "types": "./shared/types/index.d.ts"
    }
  },
  "dependencies": {
    "@comark/vue": "^0.3.1",
    "comark": "^0.3.2"
  }
}
